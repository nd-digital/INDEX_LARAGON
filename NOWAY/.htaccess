# Hidden from the web: return 404 (more discreet than 403) for any direct access.
# Contains .htpasswd (basic-auth leftover, gitignored).
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^ - [R=404,L]
</IfModule>
# Fallback if mod_rewrite is unavailable: deny outright.
<IfModule !mod_rewrite.c>
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</IfModule>
